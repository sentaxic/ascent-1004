# ─── Appwrite (required) ──────────────────────────────────────────────
# From the Appwrite console: Project → Settings (endpoint + project ID),
# and Overview → Integrations → API keys (a server key with the
# databases.* and buckets.* scopes — used server-side only).
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
# The email that is allowed to hold the "Micheal" admin account.
APPWRITE_ADMIN_EMAIL=sentaxic@gmail.com

# ─── Appwrite (optional — defaults already match the seed script) ─────
# Only set these if you named your resources differently.
APPWRITE_DATABASE_ID=ascent_1004
APPWRITE_PROFILE_BUCKET_ID=profiles
APPWRITE_POST_MEDIA_BUCKET_ID=post_media
# Collection IDs default to: profiles, sections, posts, post_media,
# comments, failure_events, mission_settings, visitor_events,
# automation_logs. Override with APPWRITE_<NAME>_COLLECTION_ID if needed.

# ─── Site / mission ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ascent-1004.vercel.app
NEXT_PUBLIC_MIT_APPLICATION_DEADLINE=2029-01-05T23:59:59+05:30
NEXT_PUBLIC_MIT_DECISION_HORIZON=2029-03-14T15:14:00+05:30
MISSION_TIME_ZONE=Asia/Kolkata
MISSED_DAY_CUTOFF_HOUR=22
CRON_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_REPOSITORY_URL=https://github.com/sentaxic/ascent-1004

# ─── Missed-day automation (optional) ─────────────────────────────────
# Use a webhook OR the Instagram Graph API (not both).
INSTAGRAM_MISSED_DAY_WEBHOOK_URL=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_GRAPH_TOKEN=
INSTAGRAM_FAILURE_IMAGE_URL=
